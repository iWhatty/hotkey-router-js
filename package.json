{
  "name": "hotkey-router",
  "version": "0.0.1",
  "description": "A tiny, deterministic keyboard routing engine for modern web apps.",
  "type": "module",
  "author": "DR.WATT",
  "license": "SEE LICENSE IN LICENSE",
  "keywords": [
    "hotkeys",
    "keyboard",
    "shortcuts",
    "router",
    "javascript"
  ],
  "main": "./dist/hotkey-router.cjs",
  "module": "./dist/hotkey-router.js",
  "exports": {
    ".": {
      "import": "./dist/hotkey-router.js",
      "require": "./dist/hotkey-router.cjs",
      "default": "./dist/hotkey-router.js"

    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node build.js",
    "prepublishOnly": "npm run build",
    "test": "vitest run --environment jsdom",
    "test:watch": "vitest --environment jsdom"
  },
  "devDependencies": {
    "esbuild": "^0.21.0",
    "jsdom": "^24.0.0",
    "vitest": "^3.1.2"
  },
  "engines": {
    "node": ">=18"
  }
}