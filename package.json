{
  "name": "hotkey-router",
  "version": "0.2.0",
  "description": "A tiny, deterministic keyboard routing engine for modern web apps.",
  "type": "module",
  "author": "WATT3D <WATT3D@protonmail.com>",
  "license": "AGPL-3.0-only",
  "keywords": [
    "hotkeys",
    "keyboard",
    "shortcuts",
    "router",
    "javascript"
  ],
  "main": "./dist/hotkey-router.cjs",
  "module": "./dist/hotkey-router.js",
  "exports": {
    ".": {
      "import": "./dist/hotkey-router.js",
      "require": "./dist/hotkey-router.cjs"
    },
    "./auto": {
      "import": "./dist/auto.js"
    },
    "./reservations": {
      "import": "./dist/reservations.js"
    },
    "./data/browser-hotkeys.json": "./data/browser-hotkeys.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "data",
    "README.md",
    "LICENSE",
    "ADDITIONAL_TERMS.md",
    "robots.txt"
  ],
  "scripts": {
    "build": "node build.js",
    "prepare": "node build.js",
    "prepublishOnly": "node build.js",
    "test": "vitest run --environment jsdom",
    "test:watch": "vitest --environment jsdom",
    "scrape:diff": "node scripts/scrape-reservations.mjs",
    "scrape:apply": "node scripts/scrape-reservations.mjs --apply"
  },
  "devDependencies": {
    "esbuild": "^0.21.0",
    "jsdom": "^24.0.0",
    "vitest": "^3.1.2"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iWhatty/hotkey-router-js.git"
  },
  "bugs": {
    "url": "https://github.com/iWhatty/hotkey-router-js/issues"
  },
  "homepage": "https://github.com/iWhatty/hotkey-router-js#readme"
}
